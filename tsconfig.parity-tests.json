{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": ".tmp/parity-tests",
    "rootDir": ".",
    "noEmit": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "src/modules/dashboard/lib/parity/**/*.ts",
    "src/types/domain.ts",
    "tests/parity/**/*.ts"
  ]
}
